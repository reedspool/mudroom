# From https://docs.deno.com/runtime/reference/docker/
FROM denoland/deno:2.8.1 AS builder
# Point Deno's cache at a known location so it can be copied to the next stage
ENV DENO_DIR=/deno-dir
WORKDIR /app

# Copy manifests first so the dependency install layer caches across
# source-only edits
COPY deno.json deno.lock package.json* ./
RUN deno ci --prod --skip-types

# Then copy the rest of the source
COPY . .

# Production stage
FROM denoland/deno:latest
ENV DENO_DIR=/deno-dir
WORKDIR /app
COPY --from=builder /app .
# Copy the populated Deno cache so the runtime stage has the dependencies
COPY --from=builder /deno-dir /deno-dir
#TODO: Look up from deno security docs: Use OS provided sandboxing mechanisms like chroot, cgroups, seccomp, etc.
ENV DENO_TRACE_PERMISSIONS=true
ENV DENO_AUDIT_PERMISSIONS=./audit_log.jsonl
CMD ["deno", "task", "serve"]
