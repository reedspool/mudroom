{
  "tasks": {
    "serve": "deno run -P main.ts",
    "test": "deno test --allow-read=./testdata",
    "test:watch": "deno test --watch"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/testing": "jsr:@std/testing@^1.0.19",
    "acorn": "npm:acorn@^8.16.0",
    "acorn-walk": "npm:acorn-walk@^8.3.5",
    "node-html-parser": "npm:node-html-parser@^7.1.0"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns",
      "esnext.full"
    ]
  },
  "permissions": {
    "default": {
      "net": ["0.0.0.0:8000"]
    }
  }
}
